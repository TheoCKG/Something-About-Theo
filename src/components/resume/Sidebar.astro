---
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isEnglish = pathname === '/en' || pathname.startsWith('/en/');

const localize = (href: string) => {
	if (isEnglish) {
		if (href === '/') return '/en/';
		return `/en${href}`;
	}
	return href;
};

const labels = isEnglish
	? {
			role: 'Combat Designer',
			home: 'Home',
			experience: 'Experience',
			blogs: 'Blogs',
			downloadCv: 'Download CV',
			socialLinks: 'SOCIAL LINKS',
			blogHome: 'Blog Home',
			gameDesign: 'Game Design',
			levelDesign: 'Level Design',
			narrativeNotes: 'Narrative Notes',
		}
	: {
			role: '战斗设计',
			home: '首页',
			experience: '经历',
			blogs: '博客',
			downloadCv: '下载简历',
			socialLinks: 'SOCIAL LINKS',
			blogHome: '博客首页',
			gameDesign: '游戏设计',
			levelDesign: '关卡设计',
			narrativeNotes: '叙事笔记',
		};

const isCurrent = (href: string) => {
	const normalizedHref = href.replace(/\/+$/, '') || '/';
	if (normalizedHref === '/') return pathname === '/';
	return pathname === normalizedHref || pathname.startsWith(`${normalizedHref}/`);
};

const isBlogRoute = isCurrent(localize('/blog'));

const blogLinks = [
	{ label: labels.blogHome, href: localize('/blog/') },
	{ label: labels.gameDesign, href: localize('/blog/game-design/first-game-design/') },
	{ label: labels.levelDesign, href: localize('/blog/level-design/first-level-design/') },
	{ label: labels.narrativeNotes, href: localize('/blog/narrative-notes/first-narrative-note/') },
];
---

<div class="resume-sidebar not-content">
	<a class="resume-profile" href={localize('/about/')}>
		<div class="resume-avatar" aria-hidden="true">T</div>
		<div class="resume-profile-copy">
			<strong>Theo</strong>
			<span>{labels.role}</span>
		</div>
	</a>

	<nav class="resume-nav" aria-label="主导航">
		<a class:list={['resume-nav-link', isCurrent(localize('/')) && 'is-active']} href={localize('/')}>
			<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10.75 12 4l8 6.75V20a1 1 0 0 1-1 1h-4.75v-5.5h-4.5V21H5a1 1 0 0 1-1-1z" fill="currentColor"/></svg>
			<span>{labels.home}</span>
		</a>

		<a class:list={['resume-nav-link', isCurrent(localize('/experience')) && 'is-active']} href={localize('/experience/work-experience/')}>
			<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4.5h12A1.5 1.5 0 0 1 19.5 6v12a1.5 1.5 0 0 1-1.5 1.5H6A1.5 1.5 0 0 1 4.5 18V6A1.5 1.5 0 0 1 6 4.5Zm1.5 3v2h9v-2Zm0 4v2h9v-2Zm0 4v2h5v-2Z" fill="currentColor"/></svg>
			<span>{labels.experience}</span>
		</a>

		<details class="resume-nav-group" open={isBlogRoute}>
			<summary class:list={['resume-nav-link', isBlogRoute && 'is-active']}>
				<span class="resume-nav-inline">
					<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 5h12a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm2 3v2h8V8Zm0 4v2h8v-2Zm0 4v2h5v-2Z" fill="currentColor"/></svg>
					<span>{labels.blogs}</span>
				</span>
				<svg class="resume-caret" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 10.5 12 14l4-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</summary>

			<div class="resume-subnav">
				{
					blogLinks.map((link) => (
						<a class:list={['resume-subnav-link', isCurrent(link.href) && 'is-active']} href={link.href}>
							{link.label}
						</a>
					))
				}
			</div>
		</details>
	</nav>

	<a class="resume-cv-button" href={localize('/experience/work-experience/')}>
		<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h8l4 4v12a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1Zm8 1.5V9h3.5ZM8 13.25h8m-8 3h8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
		<span>{labels.downloadCv}</span>
	</a>

	<div class="resume-social-block">
		<p>{labels.socialLinks}</p>
		<div class="resume-social-links">
			<a href="https://github.com/TheoCKG/Something-About-Theo" aria-label="GitHub">
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.2c-3.34.73-4.04-1.42-4.04-1.42-.54-1.38-1.33-1.75-1.33-1.75-1.08-.74.08-.73.08-.73 1.2.09 1.82 1.23 1.82 1.23 1.06 1.82 2.8 1.3 3.48.99.11-.77.41-1.3.75-1.6-2.67-.3-5.49-1.34-5.49-5.95 0-1.32.47-2.39 1.23-3.24-.12-.3-.53-1.53.12-3.18 0 0 1-.32 3.3 1.23a11.4 11.4 0 0 1 6 0c2.29-1.55 3.29-1.23 3.29-1.23.66 1.65.25 2.88.12 3.18.77.85 1.23 1.92 1.23 3.24 0 4.62-2.82 5.64-5.51 5.94.43.37.82 1.08.82 2.18v3.24c0 .32.21.7.83.58A12 12 0 0 0 12 .5Z" fill="currentColor"/></svg>
			</a>
			<a href={localize('/blog/')} aria-label={isEnglish ? 'Blog entry' : '博客入口'}>
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 7.5h11m-11 4h11m-11 4h6m-9-9.5A2.5 2.5 0 0 1 6 3.5h12A2.5 2.5 0 0 1 20.5 6v12A2.5 2.5 0 0 1 18 20.5H6A2.5 2.5 0 0 1 3.5 18V6Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</a>
		</div>
	</div>
</div>